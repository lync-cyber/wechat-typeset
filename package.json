{
  "name": "wx-md",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Browser-only Markdown editor for WeChat official-account articles: pluggable themes, 20+ container extensions, one-click rich-text copy.",
  "keywords": [
    "markdown",
    "wechat",
    "weixin",
    "editor",
    "vue",
    "markdown-to-html",
    "typesetting",
    "publishing"
  ],
  "author": "lync-cyber",
  "license": "MIT",
  "homepage": "https://github.com/lync-cyber/wechat-typeset#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/lync-cyber/wechat-typeset.git"
  },
  "bugs": {
    "url": "https://github.com/lync-cyber/wechat-typeset/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "npm run build:samples && vite",
    "build": "npm run build:samples && vue-tsc --noEmit && vite build && npm run gen:schema && npm run build:capabilities && npm run build:writer-docs -- --check",
    "build:capabilities": "tsx scripts/build-capabilities.ts",
    "build:samples": "tsx scripts/build-samples.ts",
    "build:writer-docs": "tsx scripts/build-writer-docs.ts",
    "preview": "vite preview --host 127.0.0.1 --port 7788",
    "test": "vitest run && tsx tests/verify-sample-full.ts",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "tsx tests/verify-sample-full.ts",
    "typecheck": "vue-tsc --noEmit",
    "gen:schema": "tsx scripts/gen-schema.ts",
    "gen:gallery": "tsx scripts/gen-gallery.ts",
    "validate:spec": "tsx scripts/validate-spec.ts",
    "cli": "tsx scripts/wechat-typeset-cli.ts"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.0",
    "@codemirror/lang-markdown": "^6.3.0",
    "@codemirror/lint": "^6.9.0",
    "@codemirror/state": "^6.5.0",
    "@codemirror/theme-one-dark": "^6.1.2",
    "@codemirror/view": "^6.34.1",
    "codemirror": "^6.0.1",
    "highlight.js": "^11.10.0",
    "html2canvas": "^1.4.1",
    "juice": "^11.0.0",
    "markdown-it": "^14.1.0",
    "markdown-it-container": "^4.0.0",
    "markdown-it-footnote": "^4.0.0",
    "markdown-it-ins": "^4.0.0",
    "markdown-it-mark": "^4.0.0",
    "markdown-it-task-lists": "^2.1.1",
    "vue": "^3.5.12"
  },
  "devDependencies": {
    "@codemirror/commands": "^6.10.3",
    "@types/chroma-js": "^3.1.2",
    "@types/jsdom": "^28.0.1",
    "@types/markdown-it": "^14.1.2",
    "@types/markdown-it-container": "^2.0.10",
    "@types/node": "^25.6.0",
    "@vitejs/plugin-vue": "^5.2.0",
    "@vitest/ui": "^2.1.5",
    "chroma-js": "^3.1.2",
    "jsdom": "^25.0.1",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vite-plugin-node-polyfills": "^0.22.0",
    "vitest": "^2.1.5",
    "vue-tsc": "^2.1.10"
  }
}
